TAVILY_API_KEY=your_tavily_api_key_here
DATABASE_PATH=data/research.db
FETCH_TIMEOUT_SECONDS=10
MAX_CONCURRENT_FETCHES=5

# Chunking
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=100

# Embeddings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# FAISS
FAISS_INDEX_PATH=data/faiss/index.faiss
FAISS_MAP_PATH=data/faiss/id_map.json

# Retrieval
RETRIEVAL_TOP_K=6
DENSE_RETRIEVAL_TOP_K=12
LEXICAL_RETRIEVAL_TOP_K=12
RRF_K=60

# LLM (Gemini or OpenAI)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=
MAX_CONTEXT_TOKENS=6000
MAX_OUTPUT_TOKENS=4000
GEMINI_THINKING_BUDGET=0

# Conversational Memory (Stage 3)
MAX_RECENT_TURNS=3
MAX_SUMMARY_TOKENS=400
SUMMARY_AFTER_TURNS=4

# Phase 5 — Multilingual (Sarvam AI)
SARVAM_API_KEY=your_sarvam_api_key_here
ENABLE_MULTILINGUAL=true
DEFAULT_RESPONSE_LANGUAGE=en
